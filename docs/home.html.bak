    <button id="btn-reset" onclick="clearCacheAndReload()" style="padding:5px 10px; background:#ff4757; color:white; border:none; border-radius:4px; font-weight:700; font-size:13px; cursor:pointer;" title="Refresh CSS/JS">Reset</button>
  </div>
</div>

<script>
function clearCacheAndReload() {
  var keys = Object.keys(localStorage);
  keys.forEach(function(k) {
    if (k.startsWith('enerband_')) localStorage.removeItem(k);
  });
  if ('caches' in window) {
    caches.keys().then(function(names) {
      return Promise.all(names.map(function(n) { return caches.delete(n); }));
    }).then(doReload).catch(doReload);
  } else {
    doReload();
  }
  function doReload() {
    var files = [];
    document.querySelectorAll('link[rel="stylesheet"]').forEach(function(l) {
      files.push(l.href.split('?')[0]);
    });
    document.querySelectorAll('script[src]').forEach(function(s) {
      files.push(s.src.split('?')[0]);
    });
    Promise.all(files.map(function(url) {
      return fetch(url, { cache: 'reload' }).catch(function() {});
    })).then(function() {
      window.location.replace(window.location.pathname + '?v=' + Date.now());
    });
  }
}
</script>

